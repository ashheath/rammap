# Frontend
VITE_API_URL=http://localhost:3000/api

# Backend
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/ram_tracker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ram_tracker
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# AWS S3
AWS_REGION=eu-west-2
AWS_S3_BUCKET=ram-map-photos-dev
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# CORS
CORS_ORIGIN=http://localhost:5173
# Or a comma-separated list of allowed origins for production:
# CORS_ORIGINS=https://rammaps-frontend.onrender.com,http://localhost:5173

# Supabase (if used)
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server
API_URL=http://localhost:3000
